{
  "name": "mindmate-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "clean:ports": "npx --yes kill-port 5001 5173 5174",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "npm run clean:ports && concurrently -k -n backend,frontend -c green,cyan \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1"
  }
}
